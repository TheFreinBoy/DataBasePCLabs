@page "/laboratories/edit/{Id:int}"
@using DBPCLabs.Models
@using DBPCLabs.Repositories
@inject LaboratoryRepository LabRepo
@inject NavigationManager Navigation
@inject ComputerRepository ComputerRepo

<PageTitle>Редагування лабораторії</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            
            @if (lab == null)
            {
                <div class="text-center mt-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2 text-muted">Завантаження даних...</p>
                </div>
            }
            else
            {
                <div class="shadow-sm p-5" style="background: white; border-radius: 12px; border: 1px solid #edf0f5;">
                    
                    <h3 class="fw-bold text-dark mb-4">
                        <i class="bi bi-pencil-square text-warning me-2"></i> Редагування: @lab.Name
                    </h3>
                    
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger rounded-3 d-flex align-items-center shadow-sm mb-4">
                            <i class="bi bi-shield-x me-2 fs-4"></i>
                            <div>
                                <strong>Увага!</strong> @errorMessage
                            </div>
                        </div>
                    }
                    
                    <EditForm Model="@lab" OnValidSubmit="UpdateLaboratory">
                        
                        <DataAnnotationsValidator />
                        
                        <div class="mb-4">
                            <label class="form-label fw-bold text-dark">Назва лабораторії:</label>
                            <InputText @bind-Value="lab.Name" class="form-control form-control-lg bg-light" />
                            <ValidationMessage For="@(() => lab.Name)" class="text-danger small mt-1 fw-bold" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-dark">Номер аудиторії (лише цифри):</label>
                            <InputText @bind-Value="lab.RoomNumber" class="form-control form-control-lg bg-light" />
                            <ValidationMessage For="@(() => lab.RoomNumber)" class="text-danger small mt-1 fw-bold" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-dark">Місткість (кількість ПК):</label>
                            <InputNumber @bind-Value="lab.Capacity" class="form-control form-control-lg bg-light" />
                            <ValidationMessage For="@(() => lab.Capacity)" class="text-danger small mt-1 fw-bold" />
                        </div>

                        <div class="mt-5 pt-2 border-top">
                            <button type="submit" class="btn btn-success text-dark rounded-pill px-5 py-2 shadow-sm me-3 fw-bold">
                                <i class="bi bi-save me-1"></i> Зберегти зміни
                            </button>
                            <a href="/laboratories" class="btn btn-light text-secondary rounded-pill px-4 py-2 border">
                                Скасувати
                            </a>
                        </div>
                    </EditForm>

                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int Id { get; set; }
    private string? errorMessage;

    private Laboratory? lab;

    protected override async Task OnInitializedAsync()
    {
        lab = await LabRepo.GetByIdAsync(Id);

        if (lab == null)
        {
            Navigation.NavigateTo("/laboratories");
        }
    }

    private async Task UpdateLaboratory()
    {
        errorMessage = null;
        
        int currentComputers = await ComputerRepo.CountComputersInLabAsync(lab!.Id);
        
        if (lab.Capacity < currentComputers)
        {
            errorMessage = $"Неможливо зменшити місткість до {lab.Capacity}. У цій аудиторії вже зареєстровано {currentComputers} комп'ютерів. Спочатку відкріпіть або видаліть зайві ПК.";
            return; 
        }
        
        await LabRepo.UpdateAsync(lab);
        Navigation.NavigateTo("/laboratories");
    }
}