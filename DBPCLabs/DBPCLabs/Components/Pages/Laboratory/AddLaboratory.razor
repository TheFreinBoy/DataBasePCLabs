@page "/laboratories/add"
@using DBPCLabs.Models
@using DBPCLabs.Data
@inject AppDbContext DbContext
@inject NavigationManager Navigation

<PageTitle>Додати лабораторію</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            
            <div class="shadow-sm p-5" style="background: white; border-radius: 12px; border: 1px solid #edf0f5;">
                
                <h3 class="fw-bold text-dark mb-4">Створення нової лабораторії</h3>
                
                <EditForm Model="@newLab" OnValidSubmit="SaveLaboratory">
                    
                    <DataAnnotationsValidator />
                    
                    <div class="mb-4">
                        <label class="form-label fw-bold text-dark">Назва лабораторії:</label>
                        <InputText @bind-Value="newLab.Name" class="form-control form-control-lg bg-light" placeholder="Напр.: Лабораторія програмування" />
                        <ValidationMessage For="@(() => newLab.Name)" class="text-danger small mt-1 fw-bold" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-dark">Номер аудиторії (лише цифри):</label>
                        <InputText @bind-Value="newLab.RoomNumber" class="form-control form-control-lg bg-light" placeholder="Напр.: 402" />
                        <ValidationMessage For="@(() => newLab.RoomNumber)" class="text-danger small mt-1 fw-bold" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-dark">Місткість (кількість ПК):</label>
                        <InputNumber @bind-Value="newLab.Capacity" class="form-control form-control-lg bg-light" />
                        <ValidationMessage For="@(() => newLab.Capacity)" class="text-danger small mt-1 fw-bold" />
                    </div>

                    <div class="mt-5 pt-2 border-top">
                        <button type="submit" class="btn btn-primary rounded-pill px-5 py-2 shadow-sm me-3">
                            <i class="bi bi-check-lg me-1"></i> Зберегти в базу
                        </button>
                        <a href="/laboratories" class="btn btn-light text-secondary rounded-pill px-4 py-2 border">
                            Скасувати
                        </a>
                    </div>
                </EditForm>

            </div>
        </div>
    </div>
</div>

@code {
    private Laboratory newLab = new Laboratory();
    
    private async Task SaveLaboratory()
    {
        DbContext.Laboratories.Add(newLab);
        await DbContext.SaveChangesAsync();
        Navigation.NavigateTo("/laboratories");
    }
}