@page "/laboratories"
@using DBPCLabs.Models
@using DBPCLabs.Repositories
@inject LaboratoryRepository LabRepo
@inject IJSRuntime JS 

<PageTitle>Управління лабораторіями</PageTitle>

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">Комп'ютерні лабораторії</h2>
        <a href="/laboratories/add" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold">
            <i class="bi bi-plus-lg me-1"></i> Додати нову
        </a>
    </div>

    @if (_laboratories == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Завантаження даних...</p>
        </div>
    }
    else if (!_laboratories.Any())
    {
        <div class="modern-card text-center p-5 shadow-sm" style="background: white; border-radius: 12px; border: 1px solid #edf0f5;">
            <i class="bi bi-building text-muted mb-3 d-block" style="font-size: 3rem;"></i>
            <h4 class="text-muted">У базі даних ще немає жодної лабораторії</h4>
            <a href="/laboratories/add" class="btn btn-outline-primary mt-3 rounded-pill px-4 fw-bold">Створити першу</a>
        </div>
    }
    else
    {
        <div class="shadow-sm p-4 fade-in-up" style="background: white; border-radius: 12px; border: 1px solid #edf0f5;">
            <div class="table-responsive">
                <table class="table table-hover border-white mb-0">
                    <thead class="text-secondary small text-uppercase fw-bold">
                        <tr>
                            <th class="py-3 border-0">ID</th>
                            <th class="py-3 border-0">Назва</th>
                            <th class="py-3 border-0">Аудиторія</th>
                            <th class="py-3 border-0">Місткість</th>
                            <th class="py-3 border-0 text-end">Дії</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lab in PaginatedLaboratories)
                        {
                            <tr>
                                <td class="text-muted align-middle fw-bold">#@lab.Id</td>
                                <td class="align-middle"><strong class="text-dark">@lab.Name</strong></td>
                                <td class="align-middle"><span class="badge bg-light text-dark border p-2">@lab.RoomNumber</span></td>
                                <td class="align-middle">@lab.Capacity ПК</td>
                                <td class="text-end align-middle text-nowrap">
                                    <a href="/laboratories/details/@lab.Id" class="btn btn-sm btn-light text-primary rounded-pill me-2 px-3 fw-bold border">Деталі</a>
                                    <a href="/laboratories/edit/@lab.Id" class="btn btn-sm btn-light text-success rounded-pill me-2 px-3 fw-bold border">Редагувати</a>
                                    <button class="btn btn-sm btn-light text-danger rounded-pill px-3 fw-bold border" @onclick="() => DeleteLaboratory(lab)">Видалити</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (TotalPages > 1)
            {
                <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                    <nav aria-label="Page navigation">
                        <ul class="pagination mb-0 shadow-sm" style="border-radius: 8px; overflow: hidden;">
                            <li class="page-item @(_currentPage == 1 ? "disabled" : "")">
                                <button class="page-link text-primary fw-bold" @onclick="() => GoToPage(_currentPage - 1)">
                                    <i class="bi bi-chevron-left"></i>
                                </button>
                            </li>
                            
                            @for (int i = 1; i <= TotalPages; i++)
                            {
                                int pageNumber = i; 
                                <li class="page-item @(_currentPage == pageNumber ? "active" : "")">
                                    <button class="page-link fw-bold" @onclick="() => GoToPage(pageNumber)">@pageNumber</button>
                                </li>
                            }
                            
                            <li class="page-item @(_currentPage == TotalPages ? "disabled" : "")">
                                <button class="page-link text-primary fw-bold" @onclick="() => GoToPage(_currentPage + 1)">
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    }
</div>

<style>
    .fade-in-up {
        animation: fadeInUp 0.5s ease-out forwards;
    }

    @@keyframes fadeInUp {
        0% { opacity: 0; transform: translateY(15px); }
        100% { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    private List<Laboratory>? _laboratories;
    
    private int _currentPage = 1;
    private readonly int _pageSize = 10; 

    private int TotalPages => _laboratories != null ? (int)Math.Ceiling((double)_laboratories.Count / _pageSize) : 0;

    private IEnumerable<Laboratory> PaginatedLaboratories => 
        _laboratories?.Skip((_currentPage - 1) * _pageSize).Take(_pageSize) ?? Array.Empty<Laboratory>();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _laboratories = await LabRepo.GetAllAsync();
        
        if (_laboratories != null)
        {
            _laboratories = _laboratories.OrderBy(l => l.Name).ToList();
        }
        
        if (_currentPage > TotalPages && TotalPages > 0)
        {
            _currentPage = TotalPages;
        }
    }

    private void GoToPage(int page)
    {
        if (page >= 1 && page <= TotalPages)
        {
            _currentPage = page;
        }
    }

    private async Task DeleteLaboratory(Laboratory lab)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", $"Видалити лабораторію {lab.Name}?");
        if (confirmed)
        {
            await LabRepo.DeleteAsync(lab.Id);
            await LoadData(); 
        }
    }
}