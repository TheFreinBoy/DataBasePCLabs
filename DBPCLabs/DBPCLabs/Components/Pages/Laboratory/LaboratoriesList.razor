@page "/laboratories"
@using Microsoft.EntityFrameworkCore
@using DBPCLabs.Models
@using DBPCLabs.Data
@inject AppDbContext DbContext

@inject IJSRuntime JS 

<PageTitle>Управління лабораторіями</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">Комп'ютерні лабораторії</h2>
        <a href="/laboratories/add" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-lg"></i> Додати нову
        </a>
    </div>

    @if (laboratories == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Завантаження даних...</p>
        </div>
    }
    else if (!laboratories.Any())
    {
        <div class="modern-card text-center p-5 shadow-sm" style="background: white; border-radius: 12px; border: 1px solid #edf0f5;">
            <h4 class="text-muted">У базі даних ще немає жодної лабораторії</h4>
            <a href="/laboratories/add" class="btn btn-outline-primary mt-3 rounded-pill px-4">Створити першу</a>
        </div>
    }
    else
    {
        <div class="shadow-sm p-4" style="background: white; border-radius: 12px; border: 1px solid #edf0f5;">
            <div class="table-responsive">
                <table class="table table-hover border-white mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Назва</th>
                            <th>Аудиторія</th>
                            <th>Місткість</th>
                            <th class="text-end">Дії</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lab in laboratories)
                        {
                            <tr>
                                <td class="text-muted align-middle">#@lab.Id</td>
                                <td class="align-middle"><strong class="text-dark">@lab.Name</strong></td>
                                <td class="align-middle"><span class="badge bg-light text-dark border p-2">@lab.RoomNumber</span></td>
                                <td class="align-middle">@lab.Capacity ПК</td>
                                <td class="text-end align-middle">
                             
                                    <a href="/laboratories/details/@lab.Id" class="btn btn-sm btn-light text-primary rounded-pill me-2 px-3 fw-bold">Деталі</a>
                                    
                                    <a href="/laboratories/edit/@lab.Id" class="btn btn-sm btn-light text-success rounded-pill me-2 px-3 fw-bold">Редагувати</a>
                                    
                                    <button class="btn btn-sm btn-light text-danger rounded-pill px-3 fw-bold" @onclick="() => DeleteLaboratory(lab)">Видалити</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private List<Laboratory>? laboratories;

    protected override async Task OnInitializedAsync()
    {
        laboratories = await DbContext.Laboratories.ToListAsync();
    }
    
    private async Task DeleteLaboratory(Laboratory lab)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", $"Ви дійсно хочете видалити '{lab.Name}'?\nУсі дані буде втрачено.");
        
        if (confirmed)
        {
            DbContext.Laboratories.Remove(lab);
            await DbContext.SaveChangesAsync();
            
            laboratories!.Remove(lab);
        }
    }
}