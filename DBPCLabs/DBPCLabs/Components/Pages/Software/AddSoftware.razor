@page "/software/add"
@using DBPCLabs.Models
@using DBPCLabs.Repositories
@inject SoftwareRepository SoftwareRepo
@inject NavigationManager Navigation

<PageTitle>Додати програмне забезпечення</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="shadow-sm p-5" style="background: white; border-radius: 12px; border: 1px solid #edf0f5;">
                
                <h3 class="fw-bold text-dark mb-4">Реєстрація нової програми</h3>
                
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger rounded-3 d-flex align-items-center shadow-sm mb-4">
                        <i class="bi bi-shield-x me-2 fs-4"></i>
                        <div>
                            <strong>Помилка збереження!</strong> @errorMessage
                        </div>
                    </div>
                }

                <EditForm Model="@newSoftware" OnValidSubmit="SaveSoftware">
                    <DataAnnotationsValidator />
                    
                    <div class="mb-4">
                        <label class="form-label fw-bold text-dark">Назва програми:</label>
                        <div class="input-group">
                            @if (showNewNameInput)
                            {
                                <input type="text" @bind="customName" class="form-control form-control-lg border-primary" placeholder="Введіть нову назву..." />
                                <button type="button" class="btn btn-success px-4" @onclick="AddNewName" title="Зберегти"><i class="bi bi-check-lg"></i></button>
                                <button type="button" class="btn btn-danger px-4" @onclick="() => showNewNameInput = false" title="Скасувати"><i class="bi bi-x-lg"></i></button>
                            }
                            else
                            {
                                <InputSelect @bind-Value="newSoftware.Name" class="form-select form-select-lg bg-light">
                                    <option value="" disabled selected>-- Оберіть програму зі списку --</option>
                                    @foreach (var name in predefinedNames)
                                    {
                                        <option value="@name">@name</option>
                                    }
                                </InputSelect>
                                <button type="button" class="btn btn-primary px-3 shadow-sm" @onclick="() => showNewNameInput = true" title="Додати нову програму">
                                    <i class="bi bi-plus-lg fw-bold"></i>
                                </button>
                            }
                        </div>
                        <ValidationMessage For="@(() => newSoftware.Name)" class="text-danger small mt-1 fw-bold" />
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-dark">Версія:</label>
                            <div class="input-group">
                                @if (showNewVersionInput)
                                {
                                    <input type="text" @bind="customVersion" class="form-control form-control-lg border-primary" placeholder="Нова версія..." />
                                    <button type="button" class="btn btn-success px-3" @onclick="AddNewVersion"><i class="bi bi-check-lg"></i></button>
                                    <button type="button" class="btn btn-danger px-3" @onclick="() => showNewVersionInput = false"><i class="bi bi-x-lg"></i></button>
                                }
                                else
                                {
                                    <InputSelect @bind-Value="newSoftware.Version" class="form-select form-select-lg bg-light">
                                        <option value="" disabled selected>-- Оберіть версію --</option>
                                        @foreach (var version in predefinedVersions)
                                        {
                                            <option value="@version">@version</option>
                                        }
                                    </InputSelect>
                                    <button type="button" class="btn btn-primary px-3 shadow-sm" @onclick="() => showNewVersionInput = true" title="Додати нову версію">
                                        <i class="bi bi-plus-lg"></i>
                                    </button>
                                }
                            </div>
                            <ValidationMessage For="@(() => newSoftware.Version)" class="text-danger small mt-1 fw-bold" />
                        </div>
                        
                        @* ПОЛЕ 3: ЛІЦЕНЗІЯ *@
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-dark">Тип ліцензії:</label>
                            <div class="input-group">
                                @if (showNewLicenseInput)
                                {
                                    <input type="text" @bind="customLicense" class="form-control form-control-lg border-primary" placeholder="Нова ліцензія..." />
                                    <button type="button" class="btn btn-success px-3" @onclick="AddNewLicense"><i class="bi bi-check-lg"></i></button>
                                    <button type="button" class="btn btn-danger px-3" @onclick="() => showNewLicenseInput = false"><i class="bi bi-x-lg"></i></button>
                                }
                                else
                                {
                                    <InputSelect @bind-Value="newSoftware.LicenseType" class="form-select form-select-lg bg-light">
                                        <option value="" disabled selected>-- Оберіть ліцензію --</option>
                                        @foreach (var license in predefinedLicenses)
                                        {
                                            <option value="@license">@license</option>
                                        }
                                    </InputSelect>
                                    <button type="button" class="btn btn-primary px-3 shadow-sm" @onclick="() => showNewLicenseInput = true" title="Додати нову ліцензію">
                                        <i class="bi bi-plus-lg"></i>
                                    </button>
                                }
                            </div>
                            <ValidationMessage For="@(() => newSoftware.LicenseType)" class="text-danger small mt-1 fw-bold" />
                        </div>
                    </div>

                    <div class="mt-5 pt-3 border-top">
                        <button type="submit" class="btn btn-primary rounded-pill px-5 py-2 shadow-sm me-3 fw-bold">
                            Зберегти програму
                        </button>
                        <a href="/software" class="btn btn-light text-secondary rounded-pill px-4 py-2 border fw-bold">
                            Скасувати
                        </a>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    private Software newSoftware = new Software { Name = "", Version = "", LicenseType = "" };
    private string? errorMessage;
    
    private List<string> predefinedNames = new();
    private List<string> predefinedVersions = new();
    private List<string> predefinedLicenses = new();
    
    protected override async Task OnInitializedAsync()
    {
        predefinedNames = await SoftwareRepo.GetUniqueNamesAsync();
        predefinedVersions = await SoftwareRepo.GetUniqueVersionsAsync();
        predefinedLicenses = await SoftwareRepo.GetUniqueLicensesAsync();
    }
    
    private bool showNewNameInput = false;
    private string customName = "";

    private bool showNewVersionInput = false;
    private string customVersion = "";

    private bool showNewLicenseInput = false;
    private string customLicense = "";
    
    private void AddNewName()
    {
        if (!string.IsNullOrWhiteSpace(customName))
        {
            string cleanName = customName.Trim();
            if (!predefinedNames.Contains(cleanName)) predefinedNames.Add(cleanName);
            newSoftware.Name = cleanName; 
        }
        showNewNameInput = false;
        customName = "";
    }

    private void AddNewVersion()
    {
        if (!string.IsNullOrWhiteSpace(customVersion))
        {
            string cleanVersion = customVersion.Trim();
            if (!predefinedVersions.Contains(cleanVersion)) predefinedVersions.Add(cleanVersion);
            newSoftware.Version = cleanVersion;
        }
        showNewVersionInput = false;
        customVersion = "";
    }

    private void AddNewLicense()
    {
        if (!string.IsNullOrWhiteSpace(customLicense))
        {
            string cleanLicense = customLicense.Trim();
            if (!predefinedLicenses.Contains(cleanLicense)) predefinedLicenses.Add(cleanLicense);
            newSoftware.LicenseType = cleanLicense;
        }
        showNewLicenseInput = false;
        customLicense = "";
    }
    
    private async Task SaveSoftware()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(newSoftware.Name) ||
            string.IsNullOrWhiteSpace(newSoftware.Version) ||
            string.IsNullOrWhiteSpace(newSoftware.LicenseType))
        {
            errorMessage = "Будь ласка, оберіть значення для всіх полів зі списків або додайте нові.";
            return;
        }

        bool isDuplicate = await SoftwareRepo.IsDuplicateAsync(newSoftware.Name, newSoftware.Version);

        if (isDuplicate)
        {
            errorMessage = $"Програма '{newSoftware.Name}' версії '{newSoftware.Version}' вже існує в базі!";
            return;
        }

        await SoftwareRepo.AddAsync(newSoftware);
        Navigation.NavigateTo("/software");
    }
}