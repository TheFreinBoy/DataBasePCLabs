@page "/software"
@using Microsoft.EntityFrameworkCore
@using DBPCLabs.Models
@using DBPCLabs.Repositories
@inject SoftwareRepository SoftwareRepo
@inject IJSRuntime JS 

<PageTitle>Програмне забезпечення</PageTitle>

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark m-0">Програмне забезпечення</h2>
        
        <div class="d-flex gap-3 align-items-center">
            
            <div class="shadow-sm rounded-pill" style="background: white;">
                <select class="form-select border-0 rounded-pill text-secondary fw-bold px-4 py-2" 
                        style="cursor: pointer; min-width: 220px;"
                        @onchange="SortChanged">
                    <option value="id_desc">Спершу нові (за ID ↓)</option>
                    <option value="id_asc">Спершу старі (за ID ↑)</option>
                </select>
            </div>

            <a href="/software/add" class="btn btn-primary rounded-pill px-4 py-2 shadow-sm fw-bold">
                Додати програму
            </a>
        </div>
    </div>

    @if (_softwares == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Завантаження бази програм...</p>
        </div>
    }
    else if (!_softwares.Any())
    {
        <div class="shadow-sm p-5 text-center" style="background: white; border-radius: 12px; border: 1px solid #edf0f5;">
            <i class="bi bi-disc text-muted mb-3" style="font-size: 3rem;"></i>
            <h4 class="text-muted">Жодної програми ще не додано</h4>
            <a href="/software/add" class="btn btn-outline-primary mt-3 rounded-pill px-4">Зареєструвати першу програму</a>
        </div>
    }
    else
    {
        <div class="shadow-sm p-4 fade-in-up" style="background: white; border-radius: 12px; border: 1px solid #edf0f5;">
            <div class="table-responsive">
                <table class="table table-hover border-white mb-0">
                    <thead class="text-secondary small text-uppercase fw-bold">
                        <tr>
                            <th class="py-3 border-0">ID</th>
                            <th class="py-3 border-0">Назва</th>
                            <th class="py-3 border-0">Версія</th>
                            <th class="py-3 border-0">Ліцензія</th>
                            <th class="py-3 border-0 text-end">Дії</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var soft in PaginatedSoftwares)
                        {
                            <tr>
                                <td class="align-middle text-muted fw-bold">#@soft.Id</td>
                                <td class="align-middle fw-bold text-dark">@soft.Name</td>
                                <td class="align-middle">
                                    <span class="badge bg-secondary px-2 py-1 rounded-pill">@soft.Version</span>
                                </td>
                                <td class="align-middle">
                                    @if (soft.LicenseType.Contains("Безкоштовна") || soft.LicenseType.Contains("Free"))
                                    {
                                        <span class="text-success fw-bold">@soft.LicenseType</span>
                                    }
                                    else
                                    {
                                        <span class="text-warning fw-bold">@soft.LicenseType</span>
                                    }
                                </td>
                                <td class="text-end align-middle text-nowrap">
                                    <a href="/software/edit/@soft.Id" class="btn btn-sm btn-light text-success rounded-pill me-2 px-3 fw-bold border">Редагувати</a>
                                    <button class="btn btn-sm btn-light text-danger rounded-pill px-3 fw-bold border" @onclick="() => DeleteSoftware(soft)">Видалити</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (TotalPages > 1)
            {
                <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                    <nav aria-label="Page navigation">
                        <ul class="pagination mb-0 shadow-sm" style="border-radius: 8px; overflow: hidden;">
                            <li class="page-item @(_currentPage == 1 ? "disabled" : "")">
                                <button class="page-link text-primary fw-bold" @onclick="() => GoToPage(_currentPage - 1)">
                                    <i class="bi bi-chevron-left"></i>
                                </button>
                            </li>
                            
                            @for (int i = 1; i <= TotalPages; i++)
                            {
                                int pageNumber = i; 
                                <li class="page-item @(_currentPage == pageNumber ? "active" : "")">
                                    <button class="page-link fw-bold" @onclick="() => GoToPage(pageNumber)">@pageNumber</button>
                                </li>
                            }
                            
                            <li class="page-item @(_currentPage == TotalPages ? "disabled" : "")">
                                <button class="page-link text-primary fw-bold" @onclick="() => GoToPage(_currentPage + 1)">
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    }
</div>

<style>
    .fade-in-up {
        animation: fadeInUp 0.5s ease-out forwards;
    }

    @@keyframes fadeInUp {
        0% { opacity: 0; transform: translateY(15px); }
        100% { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    private List<Software>? _softwares;
    private string _currentSort = "id_desc";
    
    private int _currentPage = 1;
    private readonly int _pageSize = 10; 

    private int TotalPages => _softwares != null ? (int)Math.Ceiling((double)_softwares.Count / _pageSize) : 0;

    private IEnumerable<Software> PaginatedSoftwares => 
        _softwares?.Skip((_currentPage - 1) * _pageSize).Take(_pageSize) ?? Array.Empty<Software>();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _softwares = await SoftwareRepo.GetAllAsync(_currentSort);
        
        if (_currentPage > TotalPages && TotalPages > 0)
        {
            _currentPage = TotalPages;
        }
    }

    private async Task SortChanged(ChangeEventArgs e)
    {
        _currentSort = e.Value?.ToString() ?? "id_desc";
        _currentPage = 1; 
        await LoadData(); 
    }

    private void GoToPage(int page)
    {
        if (page >= 1 && page <= TotalPages)
        {
            _currentPage = page;
        }
    }

    private async Task DeleteSoftware(Software soft)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", $"Видалити програму {soft.Name}?");
        if (confirmed)
        {
            await SoftwareRepo.DeleteAsync(soft.Id);
            await LoadData(); 
        }
    }
}