@page "/"
@using DBPCLabs.Models
@using DBPCLabs.Repositories
@inject LaboratoryRepository LabRepo
@inject ComputerRepository ComputerRepo
@inject SoftwareRepository SoftwareRepo
@inject ComputerSoftwareRepository InstallRepo
@inject StudentRepository StudentRepo

<PageTitle>UniLab Manager — Головна</PageTitle>

<div class="hero-section d-flex align-items-center justify-content-center position-relative">
    <div class="container py-5 fade-in-up text-center">
        
        <h1 class="display-1 text-dark mb-3 text-uppercase" style="font-weight: 900; letter-spacing: -2px;">
            UNILAB <span class="text-primary">MANAGER</span>
        </h1>
        
        <p class="text-secondary fs-4 mx-auto mb-5" style="max-width: 800px; font-weight: 500;">
            Централізована система адміністрування комп'ютерних лабораторій, інвентаризації техніки та планування розкладу.
        </p>
        
        <div class="d-flex gap-3 justify-content-center mt-2">
            <a href="#quick-access" class="btn btn-primary rounded-pill btn-lg px-5 py-3 fw-bold shadow-lg transition-all hover-lift">
                <i class="bi bi-rocket-takeoff me-2"></i> Розпочати роботу
            </a>
            <a href="/reports" class="btn btn-outline-dark rounded-pill btn-lg px-5 py-3 fw-bold transition-all hover-lift bg-white">
                <i class="bi bi-graph-up-arrow me-2"></i> Аналітика
            </a>
        </div>
    </div>
</div>

<div id="quick-access" class="cards-section container-fluid mb-5">
    <div class="container">
        <div class="text-center mb-5 pb-2">
            <h2 class="fw-bold text-dark display-6 mb-3">Огляд інфраструктури</h2>
            <p class="text-muted fs-5">Ключові показники вашої системи в реальному часі</p>
        </div>

        @if (_isLoading)
        {
            <div class="text-center my-5 py-5">
                <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;"></div>
                <p class="mt-3 text-muted fw-bold">Завантаження аналітики...</p>
            </div>
        }
        else
        {
            <div class="row g-4 justify-content-center mb-5 fade-in-up">
                
                <div class="col-md-6 col-lg-3">
                    <div class="dashboard-card shadow-sm p-4 h-100 text-center">
                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle icon-container mx-auto mb-4">
                            <i class="bi bi-door-open fs-1"></i>
                        </div>
                        <h2 class="fw-bold text-dark display-5 m-0 mb-1">@_labsCount</h2>
                        <h6 class="text-muted text-uppercase mt-2 mb-4 fw-bold tracking-wide" style="font-size: 0.8rem;">Лабораторій</h6>
                        <a href="/laboratories" class="btn btn-sm btn-light text-primary border rounded-pill px-4 py-2 fw-bold w-100 mt-2 hover-btn">Управління</a>
                    </div>
                </div>
                
                <div class="col-md-6 col-lg-3">
                    <div class="dashboard-card shadow-sm p-4 h-100 text-center">
                        <div class="bg-success bg-opacity-10 text-success rounded-circle icon-container mx-auto mb-4">
                            <i class="bi bi-pc-display fs-1"></i>
                        </div>
                        <h2 class="fw-bold text-dark display-5 m-0 mb-1">@_pcsCount</h2>
                        <h6 class="text-muted text-uppercase mt-2 mb-4 fw-bold tracking-wide" style="font-size: 0.8rem;">Комп'ютерів</h6>
                        <a href="/computers" class="btn btn-sm btn-light text-success border rounded-pill px-4 py-2 fw-bold w-100 mt-2 hover-btn">Інвентаризація</a>
                    </div>
                </div>
                
                <div class="col-md-6 col-lg-3">
                    <div class="dashboard-card shadow-sm p-4 h-100 text-center">
                        <div class="bg-warning bg-opacity-10 text-warning rounded-circle icon-container mx-auto mb-4">
                            <i class="bi bi-disc fs-1"></i>
                        </div>
                        <h2 class="fw-bold text-dark display-5 m-0 mb-1">@_softCount</h2>
                        <h6 class="text-muted text-uppercase mt-2 mb-4 fw-bold tracking-wide" style="font-size: 0.8rem;">Унікального ПЗ</h6>
                        <a href="/software" class="btn btn-sm btn-light text-warning border rounded-pill px-4 py-2 fw-bold text-dark w-100 mt-2 hover-btn">Каталог</a>
                    </div>
                </div>

                <div class="col-md-6 col-lg-3">
                    <div class="dashboard-card shadow-sm p-4 h-100 text-center">
                        <div class="bg-info bg-opacity-10 text-info rounded-circle icon-container mx-auto mb-4">
                            <i class="bi bi-people fs-1"></i>
                        </div>
                        <h2 class="fw-bold text-dark display-5 m-0 mb-1">@_studentsCount</h2>
                        <h6 class="text-muted text-uppercase mt-2 mb-4 fw-bold tracking-wide" style="font-size: 0.8rem;">Студентів у базі</h6>
                        <a href="/students" class="btn btn-sm btn-light text-info border rounded-pill px-4 py-2 fw-bold text-dark w-100 mt-2 hover-btn">База студентів</a>
                    </div>
                </div>

            </div>

            <div class="row g-4 fade-in-up align-items-start" style="animation-delay: 0.2s; animation-fill-mode: both;">
                
                <div class="col-lg-8">
                    <div class="dashboard-card shadow-sm d-flex flex-column h-100">
                        <div class="p-4 border-bottom d-flex justify-content-between align-items-center bg-white rounded-top-4">
                            <h4 class="fw-bold text-dark m-0"><i class="bi bi-cloud-arrow-down text-primary me-2"></i>Останні встановлення ПЗ</h4>
                            <a href="/installations" class="btn btn-sm btn-outline-primary rounded-pill fw-bold">Весь журнал</a>
                        </div>
                        <div class="card-body p-0 flex-grow-1">
                            @if (_recentInstallations != null && _recentInstallations.Any())
                            {
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0 align-middle">
                                        <thead class="text-secondary small text-uppercase fw-bold bg-light">
                                            <tr>
                                                <th class="ps-4 py-3 border-0">Дата</th>
                                                <th class="py-3 border-0">Програма</th>
                                                <th class="py-3 border-0">Комп'ютер</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var inst in _recentInstallations)
                                            {
                                                <tr>
                                                    <td class="ps-4 py-3 text-muted">@inst.InstallationDate.ToString("dd.MM.yyyy")</td>
                                                    <td class="py-3">
                                                        <div class="fw-bold text-dark">@inst.SoftwareName</div>
                                                        <div class="text-secondary small">v.@inst.SoftwareVersion</div>
                                                    </td>
                                                    <td class="py-3">
                                                        <span class="badge bg-light text-dark border px-3 py-2 rounded-pill">#@inst.ComputerInventoryNumber</span>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="p-5 text-center">
                                    <i class="bi bi-inbox text-muted mb-3 d-block" style="font-size: 3rem;"></i>
                                    <h5 class="text-muted fw-bold">Журнал інсталяцій порожній</h5>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="dashboard-card shadow-sm d-flex flex-column h-100">
                        <div class="p-4 border-bottom bg-white rounded-top-4">
                            <h4 class="fw-bold text-dark m-0"><i class="bi bi-lightning-charge text-warning me-2"></i>Швидкі дії</h4>
                        </div>
                        <div class="card-body p-4">
                            <div class="d-grid gap-3">
                                <a href="/reservations" class="btn btn-outline-primary text-start p-3 rounded-4 fw-bold transition-all action-btn">
                                    <i class="bi bi-calendar-plus fs-4 d-block mb-2"></i>
                                    Нове бронювання
                                </a>
                                <a href="/computers/add" class="btn btn-outline-success text-start p-3 rounded-4 fw-bold transition-all action-btn">
                                    <i class="bi bi-pc fs-4 d-block mb-2"></i>
                                    Зареєструвати ПК
                                </a>
                                <a href="/software/add" class="btn btn-outline-warning text-dark text-start p-3 rounded-4 fw-bold transition-all action-btn">
                                    <i class="bi bi-disc fs-4 d-block mb-2"></i>
                                    Додати нове ПЗ
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        }
    </div>
</div>

<style>
    .hero-section {
        background: linear-gradient(135deg, #f8f9fa 0%, #eef2f7 100%);
        min-height: 65vh; 
        border-bottom-left-radius: 50px;
        border-bottom-right-radius: 50px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.02);
    }
    
    .cards-section {
        padding-top: 4rem;
    }

    .icon-container {
        width: 70px; 
        height: 70px; 
        display: flex; 
        justify-content: center; 
        align-items: center;
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .dashboard-card {
        border-radius: 20px;
        border: 1px solid #edf0f5;
        transition: all 0.4s ease;
        background-color: #ffffff; 
        overflow: hidden; 
    }

    .dashboard-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(0,0,0,0.06) !important;
        border-color: #e2e8f0;
    }

    .dashboard-card:hover .icon-container {
        transform: scale(1.15) rotate(5deg);
    }

    .action-btn:hover {
        transform: translateX(5px);
    }

    .tracking-wide {
        letter-spacing: 1px;
    }

    .hover-lift:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 25px rgba(13, 110, 253, 0.25) !important;
    }
    
    .hover-btn:hover {
        background-color: #f8f9fa;
        filter: brightness(0.95);
    }

    .fade-in-up {
        animation: fadeInUp 0.8s ease-out forwards;
    }

    @@keyframes fadeInUp {
        0% { opacity: 0; transform: translateY(30px); }
        100% { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    private bool _isLoading = true;
    private int _labsCount = 0;
    private int _pcsCount = 0;
    private int _softCount = 0;
    private int _studentsCount = 0;

    private List<ComputerSoftware>? _recentInstallations;

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            _labsCount = (await LabRepo.GetAllAsync()).Count;
            _pcsCount = (await ComputerRepo.GetAllAsync()).Count;
            _softCount = (await SoftwareRepo.GetAllAsync("id_desc")).Count;
            _studentsCount = (await StudentRepo.GetAllAsync()).Count; 

            var allInstalls = await InstallRepo.GetAllAsync();

            _recentInstallations = allInstalls.OrderByDescending(i => i.InstallationDate).ThenByDescending(i => i.Id).Take(5).ToList();
        }
        catch (Exception)
        {
        }
        finally
        {
            _isLoading = false;
        }
    }
}