@page "/reservations"
@using DBPCLabs.Models
@using DBPCLabs.Repositories
@inject ReservationRepository ReservationRepo
@inject ComputerRepository ComputerRepo
@inject StudentRepository StudentRepo
@inject TeacherRepository TeacherRepo
@inject LaboratoryRepository LabRepo
@inject GroupRepository GroupRepo
@inject IJSRuntime JS

<PageTitle>Резервування лабораторій</PageTitle>

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark m-0">Резервування ПК та Аудиторій</h2>
            <p class="text-muted mt-1 mb-0">Управління графіком роботи в лабораторіях</p>
        </div>
        
        <div class="d-flex gap-3 align-items-center">
            @if (!_showForm)
            {
                <button class="btn btn-primary rounded-pill px-4 py-2 shadow-sm fw-bold" @onclick="ShowAddForm">
                    Нове бронювання
                </button>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger shadow-sm rounded-3 d-flex align-items-center mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2 fs-4"></i> @_errorMessage
        </div>
    }

    @if (_showForm)
    {
        <div class="shadow-sm p-4 mb-4 fade-in-up" style="background: white; border-radius: 12px; border: 1px solid #edf0f5;">
            
            <h4 class="fw-bold text-dark mb-4 text-center">
                @(_currentReservation.Id == 0 ? "Створення нового бронювання" : $"Редагування бронювання #{_currentReservation.Id}")
            </h4>

            <div class="d-flex justify-content-center mb-4">
                <div class="btn-group" role="group">
                    <input type="radio" class="btn-check" name="resType" id="typeIndiv" autocomplete="off" 
                           checked="@(!_currentReservation.IsGroupReservation)" 
                           @onchange="() => SetReservationType(false)">
                    <label class="btn btn-outline-primary px-4 fw-bold" for="typeIndiv">👤 Індивідуальне</label>

                    <input type="radio" class="btn-check" name="resType" id="typeGroup" autocomplete="off" 
                           checked="@(_currentReservation.IsGroupReservation)" 
                           @onchange="() => SetReservationType(true)">
                    <label class="btn btn-outline-primary px-4 fw-bold" for="typeGroup">👥 Групове (Пара)</label>
                </div>
            </div>

            <EditForm Model="_currentReservation" OnValidSubmit="SaveReservation">
                
                <div class="row g-4 mb-3">
                    @if (!_currentReservation.IsGroupReservation)
                    {
                        <div class="col-md-4">
                            <label class="form-label fw-bold text-dark">Комп'ютер</label>
                            <InputSelect @bind-Value="_currentReservation.ComputerId" class="form-select form-select-lg bg-light">
                                <option value="" >-- Оберіть ПК --</option>
                                @if(_computers != null) { @foreach(var c in _computers) { <option value="@c.Id">ПК #@c.InventoryNumber (Лаб. @c.LaboratoryId)</option> } }
                            </InputSelect>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold text-dark">Студент</label>
                            <InputSelect @bind-Value="_currentReservation.StudentId" class="form-select form-select-lg bg-light">
                                <option value="" >-- Оберіть студента --</option>
                                @if(_students != null) { @foreach(var s in _students) { <option value="@s.Id">@s.FullName</option> } }
                            </InputSelect>
                        </div>
                    }
                    else
                    {
                        <div class="col-md-4">
                            <label class="form-label fw-bold text-dark">Лабораторія</label>
                            <InputSelect @bind-Value="_currentReservation.LaboratoryId" class="form-select form-select-lg bg-light">
                                <option value="" >-- Оберіть лабораторію --</option>
                                @if(_labs != null) { @foreach(var l in _labs) { <option value="@l.Id">@l.Name (Ауд. @l.RoomNumber)</option> } }
                            </InputSelect>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold text-dark">Група</label>
                            <InputSelect @bind-Value="_currentReservation.GroupId" class="form-select form-select-lg bg-light">
                                <option value="" >-- Оберіть групу --</option>
                                @if(_groups != null) { @foreach(var g in _groups) { <option value="@g.Id">@g.Name</option> } }
                            </InputSelect>
                        </div>
                    }

                    <div class="col-md-4">
                        <label class="form-label fw-bold text-dark">Викладач (необов'язково)</label>
                        <InputSelect @bind-Value="_currentReservation.TeacherId" class="form-select form-select-lg bg-light">
                            <option value="">-- Без викладача --</option>
                            @if(_teachers != null) { @foreach(var t in _teachers) { <option value="@t.Id">@t.FullName</option> } }
                        </InputSelect>
                    </div>
                </div>
                
                <div class="row g-4">
                    <div class="col-md-4">
                        <label class="form-label fw-bold text-dark">Дата проведення</label>
                        <input type="date" class="form-control form-control-lg bg-light" @bind="_reservationDate" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold text-dark">Номер пари</label>
                        <select class="form-select form-select-lg bg-light fw-bold text-primary" @bind="_selectedPeriodNumber">
                            @foreach (var period in _periods)
                            {
                                <option value="@period.Number">@period.DisplayText</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold text-dark">Мета </label>
                        <InputText @bind-Value="_currentReservation.Purpose" class="form-control form-control-lg bg-light" placeholder="напр. Лаб. з БД" />
                    </div>
                </div>

                <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-3">
                    <button type="button" class="btn btn-light text-secondary rounded-pill px-4 fw-bold border" @onclick="CancelForm">Скасувати</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow-sm">
                        @(_currentReservation.Id == 0 ? "Зберегти бронювання" : "Оновити бронювання")
                    </button>
                </div>
            </EditForm>
        </div>
    }

    @if (_reservations == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Завантаження розкладу...</p>
        </div>
    }
    else if (!_reservations.Any())
    {
        <div class="shadow-sm p-5 text-center" style="background: white; border-radius: 12px; border: 1px solid #edf0f5;">
            <i class="bi bi-calendar-x text-muted mb-3" style="font-size: 3rem;"></i>
            <h4 class="text-muted">Жодного бронювання ще не створено</h4>
        </div>
    }
    else
    {
        <div class="shadow-sm p-4 fade-in-up" style="background: white; border-radius: 12px; border: 1px solid #edf0f5;">
            <div class="table-responsive">
                <table class="table table-hover border-white mb-0">
                    <thead class="text-secondary small text-uppercase fw-bold">
                        <tr>
                            <th class="py-3 border-0">ID</th>
                            <th class="py-3 border-0">Тип</th>
                            <th class="py-3 border-0">Об'єкт / Учасники</th>
                            <th class="py-3 border-0">Викладач</th>
                            <th class="py-3 border-0">Час</th>
                            <th class="py-3 border-0 text-end">Дії</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var res in PaginatedReservations)
                        {
                            // Визначаємо номер пари для відображення в таблиці
                            var matchedPeriod = _periods.FirstOrDefault(p => p.Start == res.StartTime.TimeOfDay);
                            string periodDisplay = matchedPeriod != null ? $"{matchedPeriod.Number} пара" : "Свій час";

                            <tr>
                                <td class="align-middle text-muted fw-bold">#@res.Id</td>
                                
                                <td class="align-middle">
                                    @if (res.IsGroupReservation)
                                    {
                                        <span class="badge bg-warning text-dark px-3 py-2 rounded-pill"><i class="bi bi-people-fill me-1"></i> Групове</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info text-dark px-3 py-2 rounded-pill"><i class="bi bi-person-fill me-1"></i> Індивід.</span>
                                    }
                                </td>

                                <td class="align-middle">
                                    @if (res.IsGroupReservation)
                                    {
                                        <div class="fw-bold text-dark">Лаб: @res.LaboratoryName</div>
                                        <div class="text-secondary small">Група: @res.GroupName</div>
                                    }
                                    else
                                    {
                                        <div class="fw-bold text-dark">ПК: #@res.ComputerName</div>
                                        <div class="text-secondary small">Ст: @res.StudentName</div>
                                    }
                                </td>

                                <td class="align-middle text-secondary">@(string.IsNullOrEmpty(res.TeacherName) ? "—" : res.TeacherName)</td>
                                
                                <td class="align-middle">
                                    <div class="d-flex flex-column small">
                                        <span class="text-primary fw-bold mb-1">@res.StartTime.ToString("dd.MM.yyyy")</span>
                                        <span class="badge bg-light text-dark border d-inline-block" style="width: max-content;">
                                            @periodDisplay (@res.StartTime.ToString("HH:mm") - @res.EndTime.ToString("HH:mm"))
                                        </span>
                                    </div>
                                </td>
                                
                                <td class="align-middle text-end text-nowrap">
                                    <button class="btn btn-sm btn-light text-primary rounded-pill px-3 fw-bold border me-2" @onclick="() => EditReservation(res)">Редагувати</button>
                                    <button class="btn btn-sm btn-light text-danger rounded-pill px-3 fw-bold border" @onclick="() => DeleteReservation(res.Id)">Скасувати</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (TotalPages > 1)
            {
                <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                    <nav aria-label="Page navigation">
                        <ul class="pagination mb-0 shadow-sm" style="border-radius: 8px; overflow: hidden;">
                            <li class="page-item @(_currentPage == 1 ? "disabled" : "")">
                                <button class="page-link text-primary fw-bold" @onclick="() => GoToPage(_currentPage - 1)">
                                    <i class="bi bi-chevron-left"></i>
                                </button>
                            </li>
                            
                            @for (int i = 1; i <= TotalPages; i++)
                            {
                                int pageNumber = i; 
                                <li class="page-item @(_currentPage == pageNumber ? "active" : "")">
                                    <button class="page-link fw-bold" @onclick="() => GoToPage(pageNumber)">@pageNumber</button>
                                </li>
                            }
                            
                            <li class="page-item @(_currentPage == TotalPages ? "disabled" : "")">
                                <button class="page-link text-primary fw-bold" @onclick="() => GoToPage(_currentPage + 1)">
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    }
</div>

<style>
    .fade-in-up {
        animation: fadeInUp 0.5s ease-out forwards;
    }

    @@keyframes fadeInUp {
        0% { opacity: 0; transform: translateY(15px); }
        100% { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    private List<Reservation>? _reservations;
    private List<Computer>? _computers;
    private List<Student>? _students;
    private List<Teacher>? _teachers;
    private List<DBPCLabs.Models.Laboratory>? _labs;
    private List<Group>? _groups;
    
    private Reservation _currentReservation = new();
    private bool _showForm = false;
    private string? _errorMessage;
    
    private DateTime _reservationDate = DateTime.Today;
    private int _selectedPeriodNumber = 1;

    private int _currentPage = 1;
    private readonly int _pageSize = 10;
    
    private class ClassPeriod
    {
        public int Number { get; set; }
        public TimeSpan Start { get; set; }
        public TimeSpan End { get; set; }
        public string DisplayText => $"{Number} пара ({Start:hh\\:mm} - {End:hh\\:mm})";
    }

    private List<ClassPeriod> _periods = new()
    {
        new ClassPeriod { Number = 1, Start = new TimeSpan(8, 0, 0), End = new TimeSpan(9, 20, 0) },
        new ClassPeriod { Number = 2, Start = new TimeSpan(9, 40, 0), End = new TimeSpan(11, 0, 0) },
        new ClassPeriod { Number = 3, Start = new TimeSpan(11, 20, 0), End = new TimeSpan(12, 40, 0) },
        new ClassPeriod { Number = 4, Start = new TimeSpan(13, 0, 0), End = new TimeSpan(14, 20, 0) },
        new ClassPeriod { Number = 5, Start = new TimeSpan(14, 40, 0), End = new TimeSpan(16, 0, 0) },
        new ClassPeriod { Number = 6, Start = new TimeSpan(16, 20, 0), End = new TimeSpan(17, 40, 0) }
    };

    private int TotalPages => _reservations != null ? (int)Math.Ceiling((double)_reservations.Count / _pageSize) : 0;

    private IEnumerable<Reservation> PaginatedReservations => 
        _reservations?.Skip((_currentPage - 1) * _pageSize).Take(_pageSize) ?? Array.Empty<Reservation>();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _reservations = await ReservationRepo.GetAllAsync();
        
        if (_reservations != null)
        {
            _reservations = _reservations.OrderByDescending(r => r.StartTime).ToList();
        }

        _computers = await ComputerRepo.GetAllAsync(); 
        _students = await StudentRepo.GetAllAsync();
        _teachers = await TeacherRepo.GetAllAsync();
        _labs = await LabRepo.GetAllAsync();
        _groups = await GroupRepo.GetAllAsync();
        
        if (_currentPage > TotalPages && TotalPages > 0)
        {
            _currentPage = TotalPages;
        }
    }

    private void GoToPage(int page)
    {
        if (page >= 1 && page <= TotalPages)
        {
            _currentPage = page;
        }
    }

    private void SetReservationType(bool isGroup)
    {
        _currentReservation.IsGroupReservation = isGroup;
        _currentReservation.ComputerId = null;
        _currentReservation.StudentId = null;
        _currentReservation.LaboratoryId = null;
        _currentReservation.GroupId = null;
    }

    private void ShowAddForm()
    {
        _errorMessage = null;
        
        _reservationDate = DateTime.Today;
        _selectedPeriodNumber = 1;

        _currentReservation = new Reservation 
        { 
            Id = 0, 
            IsGroupReservation = false
        }; 
        _showForm = true;
    }

    private void EditReservation(Reservation res)
    {
        _errorMessage = null;
        
        _reservationDate = res.StartTime.Date;
        var matchedPeriod = _periods.FirstOrDefault(p => p.Start == res.StartTime.TimeOfDay);
        _selectedPeriodNumber = matchedPeriod != null ? matchedPeriod.Number : 1;

        _currentReservation = new Reservation
        {
            Id = res.Id,
            IsGroupReservation = res.IsGroupReservation,
            ComputerId = res.ComputerId,
            StudentId = res.StudentId,
            LaboratoryId = res.LaboratoryId,
            GroupId = res.GroupId,
            TeacherId = res.TeacherId,
            StartTime = res.StartTime,
            EndTime = res.EndTime,
            Purpose = res.Purpose
        };
        _showForm = true;
    }

    private void CancelForm()
    {
        _showForm = false;
        _errorMessage = null;
    }

    private async Task SaveReservation()
    {
        _errorMessage = null;
        
        if (_currentReservation.IsGroupReservation)
        {
            if (_currentReservation.LaboratoryId == null || _currentReservation.LaboratoryId == 0) { _errorMessage = "Оберіть лабораторію!"; return; }
            if (_currentReservation.GroupId == null || _currentReservation.GroupId == 0) { _errorMessage = "Оберіть групу!"; return; }
        }
        else
        {
            if (_currentReservation.ComputerId == null || _currentReservation.ComputerId == 0) { _errorMessage = "Оберіть комп'ютер!"; return; }
            if (_currentReservation.StudentId == null || _currentReservation.StudentId == 0) { _errorMessage = "Оберіть студента!"; return; }
        }
        
        var period = _periods.First(p => p.Number == _selectedPeriodNumber);
        _currentReservation.StartTime = _reservationDate.Add(period.Start);
        _currentReservation.EndTime = _reservationDate.Add(period.End);

        var validationError = await ReservationRepo.ValidateReservationAsync(_currentReservation);
        if (validationError != null)
        {
            _errorMessage = validationError; 
            return;
        }

        if (_currentReservation.Id == 0)
        {
            await ReservationRepo.AddAsync(_currentReservation);
        }
        else
        {
            await ReservationRepo.UpdateAsync(_currentReservation);
        }
        
        await LoadData(); 
        _showForm = false;   
    }

    private async Task DeleteReservation(int id)
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm", "Ви впевнені, що хочете скасувати це бронювання?");
        if (confirm)
        {
            await ReservationRepo.DeleteAsync(id);
            await LoadData();
        }
    }
}