@page "/reservations"
@using DBPCLabs.Models
@using DBPCLabs.Repositories
@inject ReservationRepository ReservationRepo
@inject ComputerRepository ComputerRepo
@inject StudentRepository StudentRepo
@inject TeacherRepository TeacherRepo
@inject LaboratoryRepository LabRepo
@inject GroupRepository GroupRepo
@inject IJSRuntime JS

<PageTitle>Резервування лабораторій</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark m-0">Резервування ПК та Аудиторій</h2>
            <p class="text-muted mt-1 mb-0">Управління графіком роботи в лабораторіях</p>
        </div>
        
        <div class="d-flex gap-3 align-items-center">
            @if (!showForm)
            {
                <button class="btn btn-primary rounded-pill px-4 py-2 shadow-sm fw-bold" @onclick="ShowAddForm">
                    Нове бронювання
                </button>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger shadow-sm rounded-3 d-flex align-items-center mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2 fs-4"></i> @errorMessage
        </div>
    }

    @if (showForm)
    {
        <div class="shadow-sm p-4 mb-4 fade-in-up" style="background: white; border-radius: 12px; border: 1px solid #edf0f5;">
            
            <div class="d-flex justify-content-center mb-4">
                <div class="btn-group" role="group">
                    <input type="radio" class="btn-check" name="resType" id="typeIndiv" autocomplete="off" 
                           checked="@(!currentReservation.IsGroupReservation)" 
                           @onchange="() => SetReservationType(false)">
                    <label class="btn btn-outline-primary px-4 fw-bold" for="typeIndiv">👤 Індивідуальне</label>

                    <input type="radio" class="btn-check" name="resType" id="typeGroup" autocomplete="off" 
                           checked="@(currentReservation.IsGroupReservation)" 
                           @onchange="() => SetReservationType(true)">
                    <label class="btn btn-outline-primary px-4 fw-bold" for="typeGroup">👥 Групове (Пара)</label>
                </div>
            </div>

            <EditForm Model="currentReservation" OnValidSubmit="SaveReservation">
                
                <div class="row g-4 mb-3">
                    @if (!currentReservation.IsGroupReservation)
                    {
                        <div class="col-md-4">
                            <label class="form-label fw-bold text-dark">Комп'ютер</label>
                            <InputSelect @bind-Value="currentReservation.ComputerId" class="form-select form-select-lg bg-light">
                                <option value="" >-- Оберіть ПК --</option>
                                @if(computers != null) { @foreach(var c in computers) { <option value="@c.Id">ПК #@c.InventoryNumber (Лаб. @c.LaboratoryId)</option> } }
                            </InputSelect>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold text-dark">Студент</label>
                            <InputSelect @bind-Value="currentReservation.StudentId" class="form-select form-select-lg bg-light">
                                <option value="" >-- Оберіть студента --</option>
                                @if(students != null) { @foreach(var s in students) { <option value="@s.Id">@s.FullName</option> } }
                            </InputSelect>
                        </div>
                    }
                    else
                    {
                        <div class="col-md-4">
                            <label class="form-label fw-bold text-dark">Лабораторія</label>
                            <InputSelect @bind-Value="currentReservation.LaboratoryId" class="form-select form-select-lg bg-light">
                                <option value="" >-- Оберіть лабораторію --</option>
                                @if(labs != null) { @foreach(var l in labs) { <option value="@l.Id">@l.Name (Ауд. @l.RoomNumber)</option> } }
                            </InputSelect>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold text-dark">Група</label>
                            <InputSelect @bind-Value="currentReservation.GroupId" class="form-select form-select-lg bg-light">
                                <option value="" >-- Оберіть групу --</option>
                                @if(groups != null) { @foreach(var g in groups) { <option value="@g.Id">@g.Name</option> } }
                            </InputSelect>
                        </div>
                    }

                    <div class="col-md-4">
                        <label class="form-label fw-bold text-dark">Викладач (необов'язково)</label>
                        <InputSelect @bind-Value="currentReservation.TeacherId" class="form-select form-select-lg bg-light">
                            <option value="">-- Без викладача --</option>
                            @if(teachers != null) { @foreach(var t in teachers) { <option value="@t.Id">@t.FullName</option> } }
                        </InputSelect>
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-md-4">
                        <label class="form-label fw-bold text-dark">Час початку</label>
                        <input type="datetime-local" class="form-control form-control-lg bg-light" @bind="currentReservation.StartTime" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold text-dark">Час завершення</label>
                        <input type="datetime-local" class="form-control form-control-lg bg-light" @bind="currentReservation.EndTime" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold text-dark">Мета (Пара, Курсова...)</label>
                        <InputText @bind-Value="currentReservation.Purpose" class="form-control form-control-lg bg-light" placeholder="напр. Лаб. з БД" />
                    </div>
                </div>

                <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-3">
                    <button type="button" class="btn btn-light text-secondary rounded-pill px-4 fw-bold border" @onclick="CancelForm">Скасувати</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow-sm">
                        Зберегти бронювання
                    </button>
                </div>
            </EditForm>
        </div>
    }

    @if (reservations == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Завантаження розкладу...</p>
        </div>
    }
    else if (!reservations.Any())
    {
        <div class="shadow-sm p-5 text-center" style="background: white; border-radius: 12px; border: 1px solid #edf0f5;">
            <i class="bi bi-calendar-x text-muted mb-3" style="font-size: 3rem;"></i>
            <h4 class="text-muted">Жодного бронювання ще не створено</h4>
        </div>
    }
    else
    {
        <div class="shadow-sm p-4" style="background: white; border-radius: 12px; border: 1px solid #edf0f5;">
            <div class="table-responsive">
                <table class="table table-hover border-white mb-0">
                    <thead class="text-secondary small text-uppercase fw-bold">
                        <tr>
                            <th class="py-3 border-0">ID</th>
                            <th class="py-3 border-0">Тип</th>
                            <th class="py-3 border-0">Об'єкт / Учасники</th>
                            <th class="py-3 border-0">Викладач</th>
                            <th class="py-3 border-0">Час</th>
                            <th class="py-3 border-0 text-end">Дії</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var res in reservations)
                        {
                            <tr>
                                <td class="align-middle text-muted fw-bold">#@res.Id</td>
                                
                                <td class="align-middle">
                                    @if (res.IsGroupReservation)
                                    {
                                        <span class="badge bg-warning text-dark px-3 py-2 rounded-pill"><i class="bi bi-people-fill me-1"></i> Групове</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info text-dark px-3 py-2 rounded-pill"><i class="bi bi-person-fill me-1"></i> Індивід.</span>
                                    }
                                </td>

                                <td class="align-middle">
                                    @if (res.IsGroupReservation)
                                    {
                                        <div class="fw-bold text-dark">Лаб: @res.LaboratoryName</div>
                                        <div class="text-secondary small">Група: @res.GroupName</div>
                                    }
                                    else
                                    {
                                        <div class="fw-bold text-dark">ПК: #@res.ComputerName</div>
                                        <div class="text-secondary small">Ст: @res.StudentName</div>
                                    }
                                </td>

                                <td class="align-middle text-secondary">@(string.IsNullOrEmpty(res.TeacherName) ? "—" : res.TeacherName)</td>
                                
                                <td class="align-middle">
                                    <div class="d-flex flex-column small">
                                        <span class="text-success fw-bold">@res.StartTime.ToString("dd.MM HH:mm")</span>
                                        <span class="text-danger fw-bold">@res.EndTime.ToString("dd.MM HH:mm")</span>
                                    </div>
                                </td>
                                
                                <td class="align-middle text-end">
                                    <button class="btn btn-sm btn-light text-danger rounded-pill px-3 fw-bold border" @onclick="() => DeleteReservation(res.Id)">Скасувати</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private List<Reservation>? reservations;
    private List<Computer>? computers;
    private List<Student>? students;
    private List<Teacher>? teachers;
    private List<DBPCLabs.Models.Laboratory>? labs;
    private List<Group>? groups;
    
    private Reservation currentReservation = new();
    private bool showForm = false;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        reservations = await ReservationRepo.GetAllAsync();
        computers = await ComputerRepo.GetAllAsync(); 
        students = await StudentRepo.GetAllAsync();
        teachers = await TeacherRepo.GetAllAsync();
        labs = await LabRepo.GetAllAsync();
        groups = await GroupRepo.GetAllAsync();
    }

    private void SetReservationType(bool isGroup)
    {
        currentReservation.IsGroupReservation = isGroup;
        currentReservation.ComputerId = null;
        currentReservation.StudentId = null;
        currentReservation.LaboratoryId = null;
        currentReservation.GroupId = null;
    }

    private void ShowAddForm()
    {
        errorMessage = null;
        currentReservation = new Reservation 
        { 
            IsGroupReservation = false,
            StartTime = DateTime.Today.AddHours(9),
            EndTime = DateTime.Today.AddHours(10).AddMinutes(30)
        }; 
        showForm = true;
    }

    private void CancelForm()
    {
        showForm = false;
        errorMessage = null;
    }

    private async Task SaveReservation()
    {
        errorMessage = null;
        
        if (currentReservation.IsGroupReservation)
        {
            if (currentReservation.LaboratoryId == null || currentReservation.LaboratoryId == 0) { errorMessage = "Оберіть лабораторію!"; return; }
            if (currentReservation.GroupId == null || currentReservation.GroupId == 0) { errorMessage = "Оберіть групу!"; return; }
        }
        else
        {
            if (currentReservation.ComputerId == null || currentReservation.ComputerId == 0) { errorMessage = "Оберіть комп'ютер!"; return; }
            if (currentReservation.StudentId == null || currentReservation.StudentId == 0) { errorMessage = "Оберіть студента!"; return; }
        }

        if (currentReservation.StartTime >= currentReservation.EndTime)
        {
            errorMessage = "Час завершення має бути пізніше часу початку!"; return;
        }


        var validationError = await ReservationRepo.ValidateReservationAsync(currentReservation);
        if (validationError != null)
        {
            errorMessage = validationError; 
            return;
        }

        await ReservationRepo.AddAsync(currentReservation);
        await LoadData(); 
        showForm = false;   
    }

    private async Task DeleteReservation(int id)
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm", "Ви впевнені, що хочете скасувати це бронювання?");
        if (confirm)
        {
            await ReservationRepo.DeleteAsync(id);
            await LoadData();
        }
    }
}