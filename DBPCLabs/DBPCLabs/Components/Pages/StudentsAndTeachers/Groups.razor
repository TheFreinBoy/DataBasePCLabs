@page "/groups"
@using DBPCLabs.Models
@using DBPCLabs.Repositories
@inject GroupRepository GroupRepo
@inject StudentRepository StudentRepo
@inject DepartmentRepository DepartmentRepo
@inject IJSRuntime JS

<PageTitle>Академічні групи</PageTitle>

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark m-0">Академічні групи</h2>
        
        <div class="d-flex gap-3 align-items-center">
            @if (!_showForm)
            {
                <button class="btn btn-primary rounded-pill px-4 py-2 shadow-sm fw-bold" @onclick="ShowAddForm">
                    Додати групу
                </button>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger shadow-sm rounded-3 d-flex align-items-center mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2 fs-4"></i> @_errorMessage
        </div>
    }

    @if (_showForm)
    {
        <div class="shadow-sm p-4 mb-4 fade-in-up" style="background: white; border-radius: 12px; border: 1px solid #edf0f5;">
            <h4 class="fw-bold text-dark mb-4">@(_isEditing ? "Редагування групи" : "Реєстрація нової групи")</h4>
            
            @if (_departments == null || !_departments.Any())
            {
                <div class="alert alert-warning">
                    <i class="bi bi-info-circle me-2"></i> <strong>Увага:</strong> Ви ще не створили жодної кафедри. Будь ласка, спочатку додайте кафедру до бази.
                </div>
                <button type="button" class="btn btn-light rounded-pill px-4 fw-bold" @onclick="CancelForm">Скасувати</button>
            }
            else
            {
                <EditForm Model="_currentGroup" OnValidSubmit="SaveGroup">
                    <DataAnnotationsValidator />
                    <div class="row g-4">
                        <div class="col-md-5">
                            <label class="form-label fw-bold text-dark">Назва групи (напр. ПЗ-22-1)</label>
                            <InputText @bind-Value="_currentGroup.Name" class="form-control form-control-lg bg-light" placeholder="Введіть назву..." />
                            <ValidationMessage For="@(() => _currentGroup.Name)" class="text-danger small mt-1 fw-bold" />
                        </div>
                        <div class="col-md-7">
                            <label class="form-label fw-bold text-dark">Кафедра</label>
                            <InputSelect @bind-Value="_currentGroup.DepartmentId" class="form-select form-select-lg bg-light">
                                <option value="0" disabled>-- Оберіть кафедру --</option>
                                @foreach (var dep in _departments)
                                {
                                    <option value="@dep.Id">@dep.Name (@dep.Faculty)</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => _currentGroup.DepartmentId)" class="text-danger small mt-1 fw-bold" />
                        </div>
                    </div>
                    <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-3">
                        <button type="button" class="btn btn-light text-secondary rounded-pill px-4 fw-bold border" @onclick="CancelForm">Скасувати</button>
                        <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow-sm">
                            Зберегти
                        </button>
                    </div>
                </EditForm>
            }
        </div>
    }

    @if (_groups == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Завантаження бази груп...</p>
        </div>
    }
    else if (!_groups.Any())
    {
        <div class="shadow-sm p-5 text-center" style="background: white; border-radius: 12px; border: 1px solid #edf0f5;">
            <i class="bi bi-people text-muted mb-3" style="font-size: 3rem;"></i>
            <h4 class="text-muted">Жодної групи ще не додано</h4>
            <button class="btn btn-outline-primary mt-3 rounded-pill px-4" @onclick="ShowAddForm">Зареєструвати першу групу</button>
        </div>
    }
    else
    {
        <div class="shadow-sm p-4 fade-in-up" style="background: white; border-radius: 12px; border: 1px solid #edf0f5;">
            <div class="table-responsive">
                <table class="table table-hover border-white mb-0">
                    <thead class="text-secondary small text-uppercase fw-bold">
                        <tr>
                            <th class="py-3 border-0" style="width: 80px;">ID</th>
                            <th class="py-3 border-0">Назва групи</th>
                            <th class="py-3 border-0">Кафедра</th>
                            <th class="py-3 border-0 text-end" style="width: 320px;">Дії</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var group in PaginatedGroups)
                        {
                            <tr>
                                <td class="align-middle text-muted fw-bold">#@group.Id</td>
                                <td class="align-middle fw-bold text-dark">@group.Name</td>
                                <td class="align-middle text-secondary">@group.DepartmentName</td>
                                <td class="align-middle">
                                    <div class="d-flex justify-content-end align-items-center gap-2 flex-nowrap">
                                        <button class="btn btn-sm btn-light text-primary rounded-pill px-3 fw-bold border" @onclick="() => ShowStudentsList(group)">
                                            Студенти
                                        </button>
                                        <button class="btn btn-sm btn-light text-success rounded-pill px-3 fw-bold border" @onclick="() => EditGroup(group)">
                                            Редагувати
                                        </button>
                                        <button class="btn btn-sm btn-light text-danger rounded-pill px-3 fw-bold border" @onclick="() => DeleteGroup(group.Id)">
                                            Видалити
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (TotalPages > 1)
            {
                <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                    <nav aria-label="Page navigation">
                        <ul class="pagination mb-0 shadow-sm" style="border-radius: 8px; overflow: hidden;">
                            <li class="page-item @(_currentPage == 1 ? "disabled" : "")">
                                <button class="page-link text-primary fw-bold" @onclick="() => GoToPage(_currentPage - 1)">
                                    <i class="bi bi-chevron-left"></i>
                                </button>
                            </li>
                            
                            @for (int i = 1; i <= TotalPages; i++)
                            {
                                int pageNumber = i; 
                                <li class="page-item @(_currentPage == pageNumber ? "active" : "")">
                                    <button class="page-link fw-bold" @onclick="() => GoToPage(pageNumber)">@pageNumber</button>
                                </li>
                            }
                            
                            <li class="page-item @(_currentPage == TotalPages ? "disabled" : "")">
                                <button class="page-link text-primary fw-bold" @onclick="() => GoToPage(_currentPage + 1)">
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    }
</div>

@if (_viewingGroup != null)
{
    <div class="custom-modal-backdrop" @onclick="CloseStudentsList"></div>
    <div class="custom-modal-dialog shadow-lg modal-fade-in" style="background: white; border-radius: 16px; border: 1px solid #edf0f5;">
        
        <div class="p-4 border-bottom d-flex justify-content-between align-items-center">
            <div>
                <h4 class="fw-bold text-dark m-0">Студенти групи @_viewingGroup.Name</h4>
                <small class="text-muted">@_viewingGroup.DepartmentName</small>
            </div>
            <button type="button" class="btn-close" @onclick="CloseStudentsList"></button>
        </div>
        
        <div class="p-4" style="max-height: 50vh; overflow-y: auto;">
            @if (_groupStudents == null)
            {
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            }
            else if (!_groupStudents.Any())
            {
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-person-x fs-1 mb-2"></i>
                    <p class="m-0 fs-5">У цій групі ще немає жодного студента.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="text-secondary small text-uppercase fw-bold">
                            <tr>
                                <th class="py-2 border-0">ID</th>
                                <th class="py-2 border-0">ПІБ Студента</th>
                                <th class="py-2 border-0">Email</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var student in _groupStudents)
                            {
                                <tr>
                                    <td class="text-muted fw-bold align-middle">#@student.Id</td>
                                    <td class="fw-bold text-dark align-middle">@student.FullName</td>
                                    <td class="text-secondary align-middle">@student.Email</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
        
        <div class="p-4 border-top text-end bg-light" style="border-bottom-left-radius: 16px; border-bottom-right-radius: 16px;">
            <a href="/students" class="btn btn-outline-primary rounded-pill px-4 fw-bold me-2">Перейти до всіх студентів</a>
            <button class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm" @onclick="CloseStudentsList">Закрити</button>
        </div>
    </div>
}

<style>
    .custom-modal-backdrop {
        position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
        background-color: rgba(0,0,0,0.4); backdrop-filter: blur(4px); z-index: 1050;
    }
    .custom-modal-dialog {
        position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);
        width: 90%; max-width: 800px; z-index: 1055; display: flex; flex-direction: column;
    }
    .modal-fade-in {
        animation: modalFadeIn 0.3s ease-out forwards;
    }
    @@keyframes modalFadeIn {
        0% { opacity: 0; transform: translate(-50%, -45%); }
        100% { opacity: 1; transform: translate(-50%, -50%); }
    }
</style>

@code {
    private List<Group>? _groups;
    private List<Department>? _departments; 
    private Group _currentGroup = new();
    private bool _showForm = false;
    private bool _isEditing = false;
    private string? _errorMessage;

    private Group? _viewingGroup = null;
    private List<Student>? _groupStudents = null;
    
    private int _currentPage = 1;
    private readonly int _pageSize = 10;

    private int TotalPages => _groups != null ? (int)Math.Ceiling((double)_groups.Count / _pageSize) : 0;

    private IEnumerable<Group> PaginatedGroups => 
        _groups?.Skip((_currentPage - 1) * _pageSize).Take(_pageSize) ?? Array.Empty<Group>();

    protected override async Task OnInitializedAsync()
    {
        await LoadGroups();
    }

    private async Task LoadGroups()
    {
        _groups = await GroupRepo.GetAllAsync();
        _departments = await DepartmentRepo.GetAllAsync();
        
        if (_currentPage > TotalPages && TotalPages > 0)
        {
            _currentPage = TotalPages;
        }
    }

    private void GoToPage(int page)
    {
        if (page >= 1 && page <= TotalPages)
        {
            _currentPage = page;
        }
    }

    private async Task ShowStudentsList(Group group)
    {
        _viewingGroup = group;
        _groupStudents = null; 
        StateHasChanged(); 
        _groupStudents = await StudentRepo.GetStudentsByGroupAsync(group.Id);
    }

    private void CloseStudentsList()
    {
        _viewingGroup = null;
        _groupStudents = null;
    }

    private void ShowAddForm()
    {
        _errorMessage = null;
        _currentGroup = new Group { DepartmentId = 0 }; 
        _isEditing = false;
        _showForm = true;
    }

    private void EditGroup(Group group)
    {
        _errorMessage = null;
        _currentGroup = new Group { Id = group.Id, Name = group.Name, DepartmentId = group.DepartmentId };
        _isEditing = true;
        _showForm = true;
    }

    private void CancelForm()
    {
        _showForm = false;
        _errorMessage = null;
    }

    private async Task SaveGroup()
    {
        _errorMessage = null;

        if (_currentGroup.DepartmentId == 0)
        {
            _errorMessage = "Будь ласка, оберіть кафедру зі списку!";
            return;
        }

        bool isDuplicate = await GroupRepo.IsDuplicateNameAsync(_currentGroup.Name.Trim(), _isEditing ? _currentGroup.Id : null);
        if (isDuplicate)
        {
            _errorMessage = $"Група з назвою '{_currentGroup.Name}' вже існує!";
            return;
        }

        if (_isEditing)
        {
            await GroupRepo.UpdateAsync(_currentGroup);
        }
        else
        {
            await GroupRepo.AddAsync(_currentGroup);
        }

        await LoadGroups(); 
        _showForm = false;   
    }

    private async Task DeleteGroup(int id)
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm", "Ви впевнені, що хочете видалити цю групу? Всі студенти цієї групи також будуть видалені!");
        if (confirm)
        {
            await GroupRepo.DeleteAsync(id);
            await LoadGroups();
        }
    }
}