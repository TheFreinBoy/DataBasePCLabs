@page "/students"
@using DBPCLabs.Models
@using DBPCLabs.Repositories
@inject StudentRepository StudentRepo
@inject GroupRepository GroupRepo
@inject IJSRuntime JS

<PageTitle>База студентів</PageTitle>

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark m-0">База студентів</h2>
        
        <div class="d-flex gap-3 align-items-center">
            @if (!_showForm)
            {
                <button class="btn btn-primary rounded-pill px-4 py-2 shadow-sm fw-bold" @onclick="ShowAddForm">
                    Додати студента
                </button>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger shadow-sm rounded-3 d-flex align-items-center mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2 fs-4"></i> @_errorMessage
        </div>
    }

    @if (_showForm)
    {
        <div class="shadow-sm p-4 mb-4 fade-in-up" style="background: white; border-radius: 12px; border: 1px solid #edf0f5;">
            <h4 class="fw-bold text-dark mb-4">@(_isEditing ? "Редагування профілю" : "Реєстрація нового студента")</h4>
            
            @if (_groups == null || !_groups.Any())
            {
                <div class="alert alert-warning">
                    <i class="bi bi-info-circle me-2"></i> <strong>Увага:</strong> Ви ще не створили жодної академічної групи. Будь ласка, <a href="/groups" class="alert-link">додайте групу</a> перед реєстрацією студентів.
                </div>
                <button type="button" class="btn btn-light rounded-pill px-4 fw-bold" @onclick="CancelForm">Скасувати</button>
            }
            else
            {
                <EditForm Model="_currentStudent" OnValidSubmit="SaveStudent">
                    <DataAnnotationsValidator />
                    <div class="row g-4">
                        <div class="col-md-4">
                            <label class="form-label fw-bold text-dark">ПІБ студента</label>
                            <InputText @bind-Value="_currentStudent.FullName" class="form-control form-control-lg bg-light" placeholder="Іванов Іван..." />
                            <ValidationMessage For="@(() => _currentStudent.FullName)" class="text-danger small mt-1 fw-bold" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold text-dark">Email адреса</label>
                            <InputText @bind-Value="_currentStudent.Email" type="email" class="form-control form-control-lg bg-light" placeholder="student@unilab.edu..." />
                            <ValidationMessage For="@(() => _currentStudent.Email)" class="text-danger small mt-1 fw-bold" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold text-dark">Академічна група</label>
                            <InputSelect @bind-Value="_currentStudent.GroupId" class="form-select form-select-lg bg-light">
                                <option value="0" disabled>-- Оберіть групу --</option>
                                @foreach (var group in _groups)
                                {
                                    <option value="@group.Id">@group.Name (@group.DepartmentName)</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => _currentStudent.GroupId)" class="text-danger small mt-1 fw-bold" />
                        </div>
                    </div>
                    <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-3">
                        <button type="button" class="btn btn-light text-secondary rounded-pill px-4 fw-bold border" @onclick="CancelForm">Скасувати</button>
                        <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow-sm">
                            Зберегти
                        </button>
                    </div>
                </EditForm>
            }
        </div>
    }

    @if (_students == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Завантаження бази студентів...</p>
        </div>
    }
    else if (!_students.Any())
    {
        <div class="shadow-sm p-5 text-center" style="background: white; border-radius: 12px; border: 1px solid #edf0f5;">
            <i class="bi bi-person-badge text-muted mb-3" style="font-size: 3rem;"></i>
            <h4 class="text-muted">Жодного студента ще не додано</h4>
            <button class="btn btn-outline-primary mt-3 rounded-pill px-4" @onclick="ShowAddForm">Зареєструвати першого студента</button>
        </div>
    }
    else
    {
        <div class="shadow-sm p-4 fade-in-up" style="background: white; border-radius: 12px; border: 1px solid #edf0f5;">
            <div class="table-responsive">
                <table class="table table-hover border-white mb-0">
                    <thead class="text-secondary small text-uppercase fw-bold">
                        <tr>
                            <th class="py-3 border-0" style="width: 80px;">ID</th>
                            <th class="py-3 border-0">ПІБ Студента</th>
                            <th class="py-3 border-0">Email</th>
                            <th class="py-3 border-0">Група</th>
                            <th class="py-3 border-0 text-end" style="width: 250px;">Дії</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var student in PaginatedStudents)
                        {
                            <tr>
                                <td class="align-middle text-muted fw-bold">#@student.Id</td>
                                <td class="align-middle fw-bold text-dark">@student.FullName</td>
                                <td class="align-middle text-secondary">
                                    <i class="bi bi-envelope me-1"></i> @student.Email
                                </td>
                                <td class="align-middle">
                                    <span class="badge bg-info bg-opacity-10 text-info border border-info-subtle px-3 py-2 rounded-pill">
                                        @student.GroupName
                                    </span>
                                </td>
                                <td class="text-end align-middle text-nowrap">
                                    <button class="btn btn-sm btn-light text-success rounded-pill me-2 px-3 fw-bold border" @onclick="() => EditStudent(student)">Редагувати</button>
                                    <button class="btn btn-sm btn-light text-danger rounded-pill px-3 fw-bold border" @onclick="() => DeleteStudent(student.Id)">Видалити</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (TotalPages > 1)
            {
                <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                    <nav aria-label="Page navigation">
                        <ul class="pagination mb-0 shadow-sm" style="border-radius: 8px; overflow: hidden;">
                            <li class="page-item @(_currentPage == 1 ? "disabled" : "")">
                                <button class="page-link text-primary fw-bold" @onclick="() => GoToPage(_currentPage - 1)">
                                    <i class="bi bi-chevron-left"></i>
                                </button>
                            </li>
                            
                            @for (int i = 1; i <= TotalPages; i++)
                            {
                                int pageNumber = i; 
                                <li class="page-item @(_currentPage == pageNumber ? "active" : "")">
                                    <button class="page-link fw-bold" @onclick="() => GoToPage(pageNumber)">@pageNumber</button>
                                </li>
                            }
                            
                            <li class="page-item @(_currentPage == TotalPages ? "disabled" : "")">
                                <button class="page-link text-primary fw-bold" @onclick="() => GoToPage(_currentPage + 1)">
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    }
</div>

<style>
    .fade-in-up {
        animation: fadeInUp 0.5s ease-out forwards;
    }

    @@keyframes fadeInUp {
        0% { opacity: 0; transform: translateY(15px); }
        100% { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    private List<Student>? _students;
    private List<Group> _groups = new(); 
    private Student _currentStudent = new();
    private bool _showForm = false;
    private bool _isEditing = false;
    private string? _errorMessage;


    private int _currentPage = 1;
    private readonly int _pageSize = 10; 

    private int TotalPages => _students != null ? (int)Math.Ceiling((double)_students.Count / _pageSize) : 0;

    private IEnumerable<Student> PaginatedStudents => 
        _students?.Skip((_currentPage - 1) * _pageSize).Take(_pageSize) ?? Array.Empty<Student>();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _students = await StudentRepo.GetAllAsync();
        _groups = await GroupRepo.GetAllAsync();
        
        if (_students != null)
        {
            _students = _students.OrderBy(s => s.FullName).ToList();
        }

        if (_currentPage > TotalPages && TotalPages > 0)
        {
            _currentPage = TotalPages;
        }
    }

    private void GoToPage(int page)
    {
        if (page >= 1 && page <= TotalPages)
        {
            _currentPage = page;
        }
    }

    private void ShowAddForm()
    {
        _errorMessage = null;
        _currentStudent = new Student { GroupId = 0 }; 
        _isEditing = false;
        _showForm = true;
    }

    private void EditStudent(Student student)
    {
        _errorMessage = null;
        _currentStudent = new Student 
        { 
            Id = student.Id, 
            FullName = student.FullName, 
            Email = student.Email, 
            GroupId = student.GroupId 
        };
        _isEditing = true;
        _showForm = true;
    }

    private void CancelForm()
    {
        _showForm = false;
        _errorMessage = null;
    }

    private async Task SaveStudent()
    {
        _errorMessage = null;

        if (_currentStudent.GroupId == 0)
        {
            _errorMessage = "Будь ласка, оберіть академічну групу!";
            return;
        }
        
        if (!string.IsNullOrWhiteSpace(_currentStudent.Email))
        {
            string email = _currentStudent.Email.ToLower().Trim();
            
            if (email.EndsWith("@gmail.co") || email.EndsWith("@gmal.com") || email.EndsWith("@gmail.ru"))
            {
                return;
            }
            if (email.EndsWith("@ukr.ne"))
            {
                return;
            }

            bool isDuplicateEmail = await StudentRepo.IsDuplicateEmailAsync(_currentStudent.Email, _isEditing ? _currentStudent.Id : null);
            if (isDuplicateEmail)
            {
                _errorMessage = $"Студент з електронною поштою '{_currentStudent.Email}' вже зареєстрований у системі!";
                return;
            }
        }

        if (_isEditing)
        {
            await StudentRepo.UpdateAsync(_currentStudent);
        }
        else
        {
            await StudentRepo.AddAsync(_currentStudent);
        }

        await LoadData(); 
        _showForm = false;   
    }

    private async Task DeleteStudent(int id)
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm", "Видалити цього студента з бази?");
        if (confirm)
        {
            await StudentRepo.DeleteAsync(id);
            await LoadData(); 
        }
    }
}