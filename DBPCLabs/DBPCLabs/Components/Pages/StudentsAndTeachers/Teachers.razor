@page "/teachers"
@using DBPCLabs.Models
@using DBPCLabs.Repositories
@inject TeacherRepository TeacherRepo
@inject DepartmentRepository DepartmentRepo
@inject IJSRuntime JS

<PageTitle>Склад викладачів</PageTitle>

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark m-0">Склад викладачів</h2>
        
        <div class="d-flex gap-3 align-items-center">
            @if (!_showForm)
            {
                <button class="btn btn-primary rounded-pill px-4 py-2 shadow-sm fw-bold" @onclick="ShowAddForm">
                    Додати викладача
                </button>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger shadow-sm rounded-3 d-flex align-items-center mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2 fs-4"></i> @_errorMessage
        </div>
    }

    @if (_showForm)
    {
        <div class="shadow-sm p-4 mb-4 fade-in-up" style="background: white; border-radius: 12px; border: 1px solid #edf0f5;">
            <h4 class="fw-bold text-dark mb-4">@(_isEditing ? "Редагування профілю" : "Реєстрація викладача")</h4>
            
            @if (_departments == null || !_departments.Any())
            {
                <div class="alert alert-warning">
                    <i class="bi bi-info-circle me-2"></i> <strong>Увага:</strong> Ви ще не створили жодної кафедри. Будь ласка, спочатку додайте кафедру до бази.
                </div>
                <button type="button" class="btn btn-light rounded-pill px-4 fw-bold" @onclick="CancelForm">Скасувати</button>
            }
            else
            {
                <EditForm Model="_currentTeacher" OnValidSubmit="SaveTeacher">
                    <DataAnnotationsValidator />
                    <div class="row g-4">
                        <div class="col-md-4">
                            <label class="form-label fw-bold text-dark">ПІБ Викладача</label>
                            <InputText @bind-Value="_currentTeacher.FullName" class="form-control form-control-lg bg-light" placeholder="Шевченко О. М." />
                            <ValidationMessage For="@(() => _currentTeacher.FullName)" class="text-danger small mt-1 fw-bold" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold text-dark">Email адреса</label>
                            <InputText @bind-Value="_currentTeacher.Email" type="email" class="form-control form-control-lg bg-light" placeholder="teacher@unilab.edu" />
                            <ValidationMessage For="@(() => _currentTeacher.Email)" class="text-danger small mt-1 fw-bold" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold text-dark">Кафедра</label>
                            <InputSelect @bind-Value="_currentTeacher.DepartmentId" class="form-select form-select-lg bg-light">
                                <option value="0" disabled>-- Оберіть кафедру --</option>
                                @foreach (var dep in _departments)
                                {
                                    <option value="@dep.Id">@dep.Name (@dep.Faculty)</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => _currentTeacher.DepartmentId)" class="text-danger small mt-1 fw-bold" />
                        </div>
                    </div>
                    <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-3">
                        <button type="button" class="btn btn-light text-secondary rounded-pill px-4 fw-bold border" @onclick="CancelForm">Скасувати</button>
                        <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow-sm">
                            Зберегти
                        </button>
                    </div>
                </EditForm>
            }
        </div>
    }

    @if (_teachers == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Завантаження бази викладачів...</p>
        </div>
    }
    else if (!_teachers.Any())
    {
        <div class="shadow-sm p-5 text-center" style="background: white; border-radius: 12px; border: 1px solid #edf0f5;">
            <i class="bi bi-person-workspace text-muted mb-3" style="font-size: 3rem;"></i>
            <h4 class="text-muted">Жодного викладача ще не додано</h4>
            <button class="btn btn-outline-primary mt-3 rounded-pill px-4" @onclick="ShowAddForm">Додати першого викладача</button>
        </div>
    }
    else
    {
        <div class="shadow-sm p-4 fade-in-up" style="background: white; border-radius: 12px; border: 1px solid #edf0f5;">
            <div class="table-responsive">
                <table class="table table-hover border-white mb-0">
                    <thead class="text-secondary small text-uppercase fw-bold">
                        <tr>
                            <th class="py-3 border-0" style="width: 80px;">ID</th>
                            <th class="py-3 border-0">ПІБ Викладача</th>
                            <th class="py-3 border-0">Кафедра</th>
                            <th class="py-3 border-0">Email</th>
                            <th class="py-3 border-0 text-end" style="width: 250px;">Дії</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var teacher in PaginatedTeachers)
                        {
                            <tr>
                                <td class="align-middle text-muted fw-bold">#@teacher.Id</td>
                                <td class="align-middle fw-bold text-dark">@teacher.FullName</td>
                                <td class="align-middle">
                                    <span class="badge bg-secondary px-3 py-2 rounded-pill">@teacher.DepartmentName</span>
                                </td>
                                <td class="align-middle text-secondary">
                                    <i class="bi bi-envelope me-1"></i> @teacher.Email
                                </td>
                                <td class="align-middle">
                                    <div class="d-flex justify-content-end align-items-center gap-2 flex-nowrap">
                                        <button class="btn btn-sm btn-light text-success rounded-pill px-3 fw-bold border" @onclick="() => EditTeacher(teacher)">Редагувати</button>
                                        <button class="btn btn-sm btn-light text-danger rounded-pill px-3 fw-bold border" @onclick="() => DeleteTeacher(teacher.Id)">Видалити</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (TotalPages > 1)
            {
                <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                    <nav aria-label="Page navigation">
                        <ul class="pagination mb-0 shadow-sm" style="border-radius: 8px; overflow: hidden;">
                            <li class="page-item @(_currentPage == 1 ? "disabled" : "")">
                                <button class="page-link text-primary fw-bold" @onclick="() => GoToPage(_currentPage - 1)">
                                    <i class="bi bi-chevron-left"></i>
                                </button>
                            </li>
                            
                            @for (int i = 1; i <= TotalPages; i++)
                            {
                                int pageNumber = i; 
                                <li class="page-item @(_currentPage == pageNumber ? "active" : "")">
                                    <button class="page-link fw-bold" @onclick="() => GoToPage(pageNumber)">@pageNumber</button>
                                </li>
                            }
                            
                            <li class="page-item @(_currentPage == TotalPages ? "disabled" : "")">
                                <button class="page-link text-primary fw-bold" @onclick="() => GoToPage(_currentPage + 1)">
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    }
</div>

<style>
    .fade-in-up {
        animation: fadeInUp 0.5s ease-out forwards;
    }

    @@keyframes fadeInUp {
        0% { opacity: 0; transform: translateY(15px); }
        100% { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    private List<Teacher>? _teachers;
    private List<Department>? _departments; 
    private Teacher _currentTeacher = new();
    private bool _showForm = false;
    private bool _isEditing = false;
    private string? _errorMessage;
    
    private int _currentPage = 1;
    private readonly int _pageSize = 10; 

    private int TotalPages => _teachers != null ? (int)Math.Ceiling((double)_teachers.Count / _pageSize) : 0;

    private IEnumerable<Teacher> PaginatedTeachers => 
        _teachers?.Skip((_currentPage - 1) * _pageSize).Take(_pageSize) ?? Array.Empty<Teacher>();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _teachers = await TeacherRepo.GetAllAsync();
        _departments = await DepartmentRepo.GetAllAsync();
        
        if (_teachers != null)
        {
            _teachers = _teachers.OrderBy(t => t.FullName).ToList();
        }
        
        if (_currentPage > TotalPages && TotalPages > 0)
        {
            _currentPage = TotalPages;
        }
    }

    private void GoToPage(int page)
    {
        if (page >= 1 && page <= TotalPages)
        {
            _currentPage = page;
        }
    }

    private void ShowAddForm()
    {
        _errorMessage = null;
        _currentTeacher = new Teacher { DepartmentId = 0 }; 
        _isEditing = false;
        _showForm = true;
    }

    private void EditTeacher(Teacher teacher)
    {
        _errorMessage = null;
        _currentTeacher = new Teacher 
        { 
            Id = teacher.Id, 
            FullName = teacher.FullName, 
            DepartmentId = teacher.DepartmentId, 
            Email = teacher.Email
        };
        _isEditing = true;
        _showForm = true;
    }

    private void CancelForm()
    {
        _showForm = false;
        _errorMessage = null;
    }

    private async Task SaveTeacher()
    {
        _errorMessage = null;
        
        if (_currentTeacher.DepartmentId == 0)
        {
            _errorMessage = "Будь ласка, оберіть кафедру зі списку!";
            return;
        }
        
        if (!string.IsNullOrWhiteSpace(_currentTeacher.Email))
        {
            string email = _currentTeacher.Email.ToLower().Trim();
            if (email.EndsWith("@gmail.co") || email.EndsWith("@gmal.com") || email.EndsWith("@gmail.ru"))
            {
                _errorMessage = "Схоже на опечатку в Email. Можливо, ви мали на увазі @gmail.com?";
                return;
            }
            if (email.EndsWith("@ukr.ne"))
            {
                _errorMessage = "Схоже на опечатку. Ви мали на увазі @ukr.net?";
                return;
            }
            
            bool isDuplicate = await TeacherRepo.IsDuplicateEmailAsync(email, _isEditing ? _currentTeacher.Id : null);
            if (isDuplicate)
            {
                _errorMessage = $"Викладач з поштою '{_currentTeacher.Email}' вже зареєстрований!";
                return;
            }
        }

        if (_isEditing)
        {
            await TeacherRepo.UpdateAsync(_currentTeacher);
        }
        else
        {
            await TeacherRepo.AddAsync(_currentTeacher);
        }

        await LoadData(); 
        _showForm = false;   
    }

    private async Task DeleteTeacher(int id)
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm", "Видалити цього викладача з бази?");
        if (confirm)
        {
            await TeacherRepo.DeleteAsync(id);
            await LoadData();
        }
    }
}