@inject IJSRuntime JS

<nav class="header-nav shadow-sm w-100">
    <div class="container h-100 d-flex justify-content-between align-items-center">
        
        <div class="d-flex align-items-center">
            <a class="text-white fw-bold d-flex align-items-center m-0 p-0 text-decoration-none me-4" href="">
                <i class="bi bi-cpu text-primary me-2" style="font-size: 1.5rem;"></i>
                <span style="font-size: 1.25rem; letter-spacing: 0.5px;">UniLab Manager</span>
            </a>

            <div class="d-flex align-items-center gap-3">
                <NavLink class="custom-btn" href="departments">
                    Кафедри
                </NavLink>
                <NavLink class="custom-btn" href="laboratories">
                    Лабораторії
                </NavLink>
                <NavLink class="custom-btn" href="computers">
                    Комп'ютери
                </NavLink>
                <NavLink class="custom-btn" href="/software" Match="NavLinkMatch.Prefix">
                    ПЗ
                </NavLink>
                <NavLink class="custom-btn" href="groups">
                    Групи
                </NavLink>
                <NavLink class="custom-btn" href="students">
                    Студенти
                </NavLink>
                <NavLink class="custom-btn" href="teachers">
                    Викладачі
                </NavLink>
                <NavLink class="custom-btn" href="reservations">
                    Резервування
                </NavLink>
            </div>
        </div>
        
        <div class="d-flex align-items-center">
            <button class="btn btn-link text-decoration-none p-0 transition-all" @onclick="ToggleTheme" title="Змінити тему оформлення">
                @if (isDarkMode)
                {
                    <i class="bi bi-sun-fill text-warning" style="font-size: 1.6rem; filter: drop-shadow(0 0 5px rgba(255, 193, 7, 0.5));"></i>
                }
                else
                {
                    <i class="bi bi-moon-stars-fill text-light hover-opacity" style="font-size: 1.4rem;"></i>
                }
            </button>
        </div>

    </div>
</nav>

@code {
    private bool isDarkMode = false;
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var savedTheme = await JS.InvokeAsync<string>("eval", "localStorage.getItem('theme')");
            if (savedTheme == "dark")
            {
                isDarkMode = true;
                StateHasChanged(); 
            }
        }
    }

    private async Task ToggleTheme()
    {
        isDarkMode = !isDarkMode;
        string theme = isDarkMode ? "dark" : "light";
        
        string jsCode = $@"
            localStorage.setItem('theme', '{theme}'); 
            document.documentElement.setAttribute('data-bs-theme', '{theme}');
            document.body.setAttribute('data-theme', '{theme}');
        ";
        
        await JS.InvokeVoidAsync("eval", jsCode);
    }
}